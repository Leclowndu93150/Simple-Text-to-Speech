{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "license": "${license}",
  "entrypoints": {
    "main": [
      "com.leclowndu93150.simpletts.SimplettsFabric"
    ],
    "client": [
      "com.leclowndu93150.simpletts.SimplettsFabricClient"
    ],
    "voicechat": [
      "com.leclowndu93150.simpletts.SimplettsFabricVoicechat"
    ],
    "modmenu": [
      "com.leclowndu93150.simpletts.SimplettsModMenu"
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "${minecraft_version}",
    "java": ">=${java_version}",
    "voicechat": "*",
    "yet_another_config_lib_v3": ">=3.6.0"
  },
  "suggests": {
    "modmenu": "*"
  }
}
